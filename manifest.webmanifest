const state = {
  pool: [],
  currentIndex: -1,
  current: null,
  activePane: "answer"
};

const universalChecks = [
  "我有說明具體情境或問題背景，不是只講理念。",
  "我有說明店長實際做了什麼管理動作。",
  "我有說明團隊如何參與、分工或被帶動。",
  "我有提供數字、前後差異、顧客回饋或具體成果。",
  "我有說明這個做法如何持續、複製或標準化。",
  "我有說出店長反思：這件事展現我的哪一項管理價值。"
];

function qs(id) { return document.getElementById(id); }
function safe(text) {
  return String(text ?? "").replace(/[&<>"']/g, ch => ({"&":"&amp;","<":"&lt;",">":"&gt;","\"":"&quot;","'":"&#039;"}[ch]));
}
function storageKey(qid) { return "tcfa_answer_" + qid; }
function doneKey(qid) { return "tcfa_done_" + qid; }
function checkKey(qid) { return "tcfa_checks_" + qid; }
function revealKey(qid) { return "tcfa_reveal_" + qid; }

function questionsByMode() {
  const mode = qs("mode").value;
  return DATA.questions.filter(q => {
    if (mode === "fast" && !q.isFast) return false;
    return true;
  });
}

function countBy(items, keyFn) {
  const counts = new Map();
  items.forEach(item => {
    const key = keyFn(item);
    if (Array.isArray(key)) {
      key.forEach(k => { if (k) counts.set(k, (counts.get(k) || 0) + 1); });
    } else if (key) {
      counts.set(key, (counts.get(key) || 0) + 1);
    }
  });
  return counts;
}

function setOptions(selectId, defaultLabel, entries, currentValue = "") {
  const select = qs(selectId);
  select.innerHTML = "";
  const all = document.createElement("option");
  all.value = "";
  all.textContent = defaultLabel;
  select.appendChild(all);

  entries.forEach(([value, count]) => {
    const opt = document.createElement("option");
    opt.value = value;
    opt.textContent = `${value}（${count}題）`;
    select.appendChild(opt);
  });

  if (currentValue && entries.some(([value]) => value === currentValue)) {
    select.value = currentValue;
  } else {
    select.value = "";
  }
}

function refreshFilterOptions() {
  const base = questionsByMode();
  const currentScenario = qs("scenario").value;
  const currentTopic = qs("topic").value;
  const currentPriority = qs("priority").value;

  const scenarioCounts = countBy(base, q => q.scenarios || []);
  const topicCounts = countBy(base, q => q.topic);

  setOptions(
    "scenario",
    "全部情境",
    Array.from(scenarioCounts.entries()).sort((a, b) => b[1] - a[1] || a[0].localeCompare(b[0], "zh-Hant")),
    currentScenario
  );
  setOptions(
    "topic",
    "全部主題",
    Array.from(topicCounts.entries()).sort((a, b) => b[1] - a[1] || a[0].localeCompare(b[0], "zh-Hant")),
    currentTopic
  );

  refreshPriorityOptions(currentPriority);
}

function refreshPriorityOptions(currentValue = qs("priority").value) {
  const scenario = qs("scenario").value;
  const topic = qs("topic").value;
  const base = questionsByMode().filter(q => {
    if (scenario && !(q.scenarios || []).includes(scenario)) return false;
    if (topic && q.topic !== topic) return false;
    return true;
  });
  const priorityCounts = countBy(base, q => q.priority);
  const order = ["高", "中高", "中"];
  setOptions(
    "priority",
    "全部優先度",
    order.filter(x => priorityCounts.has(x)).map(x => [x, priorityCounts.get(x)]),
    currentValue
  );
}

function init() {
  qs("statTotal").textContent = DATA.summary.total;
  qs("statFast").textContent = DATA.summary.fast;
  qs("statTopic").textContent = DATA.topics.length;

  refreshFilterOptions();

  qs("mode").addEventListener("change", () => {
    qs("scenario").value = "";
    qs("topic").value = "";
    qs("priority").value = "";
    refreshFilterOptions();
    buildPool();
    renderCurrentFromPool();
  });

  qs("scenario").addEventListener("change", () => {
    if (qs("scenario").value) qs("topic").value = "";
    qs("priority").value = "";
    refreshPriorityOptions();
    buildPool();
    renderCurrentFromPool();
  });

  qs("topic").addEventListener("change", () => {
    if (qs("topic").value) qs("scenario").value = "";
    qs("priority").value = "";
    refreshPriorityOptions();
    buildPool();
    renderCurrentFromPool();
  });

  qs("priority").addEventListener("change", () => {
    buildPool();
    renderCurrentFromPool();
  });

  qs("drawBtn").addEventListener("click", drawRandom);
  qs("prevBtn").addEventListener("click", () => move(-1));
  qs("nextBtn").addEventListener("click", () => move(1));
  qs("resetBtn").addEventListener("click", () => {
    qs("mode").value = "all";
    qs("scenario").value = "";
    qs("topic").value = "";
    qs("priority").value = "";
    refreshFilterOptions();
    buildPool();
    renderCurrentFromPool();
  });

  buildPool();
  updateDoneStats();
}

function buildPool() {
  const scenario = qs("scenario").value;
  const topic = qs("topic").value;
  const priority = qs("priority").value;
  state.pool = questionsByMode().filter(q => {
    if (scenario && !(q.scenarios || []).includes(scenario)) return false;
    if (topic && q.topic !== topic) return false;
    if (priority && q.priority !== priority) return false;
    return true;
  });
  state.currentIndex = Math.min(Math.max(0, state.currentIndex), state.pool.length - 1);
}

function renderCurrentFromPool() {
  if (state.pool.length === 0) {
    qs("questionCard").innerHTML = `<div class="empty">目前條件沒有符合題目，請放寬篩選條件。</div>`;
    state.current = null;
    return;
  }
  state.currentIndex = 0;
  state.current = state.pool[state.currentIndex];
  state.activePane = "answer";
  renderQuestion(state.current);
}

function drawRandom() {
  buildPool();
  if (!state.pool.length) {
    qs("questionCard").innerHTML = `<div class="empty">目前條件沒有符合題目，請放寬篩選條件。</div>`;
    return;
  }
  state.currentIndex = Math.floor(Math.random() * state.pool.length);
  state.current = state.pool[state.currentIndex];
  state.activePane = "answer";
  renderQuestion(state.current);
}

function move(delta) {
  if (!state.pool.length) buildPool();
  if (!state.pool.length) return;
  if (state.currentIndex < 0) state.currentIndex = 0;
  state.currentIndex = (state.currentIndex + delta + state.pool.length) % state.pool.length;
  state.current = state.pool[state.currentIndex];
  state.activePane = "answer";
  renderQuestion(state.current);
}

function renderQuestion(q) {
  const answer = localStorage.getItem(storageKey(q.id)) || "";
  const checks = JSON.parse(localStorage.getItem(checkKey(q.id)) || "[]");
  const done = localStorage.getItem(doneKey(q.id)) === "1";
  const revealed = localStorage.getItem(revealKey(q.id)) === "1";
  if (!revealed) state.activePane = "answer";
  if (revealed && !["answer", "compare", "guide", "skeleton"].includes(state.activePane)) state.activePane = "compare";
  const dimensionChecks = q.dimensions.slice(0, 6).map(d => "有說到：" + d);
  const allChecks = dimensionChecks.concat(universalChecks);

  const tagHtml = [
    `<span class="tag blue">${safe(q.id)}</span>`,
    `<span class="tag">${safe(q.topic)}</span>`,
    `<span class="tag orange">優先度：${safe(q.priority)}</span>`,
    q.isFast ? `<span class="tag green">快問版</span>` : "",
    revealed ? `<span class="tag green">已開啟檢視</span>` : `<span class="tag orange">先作答</span>`,
    done ? `<span class="tag green">已完成</span>` : ""
  ].join("");

  const scenarioHtml = q.scenarios.length
    ? `<div class="small">對應情境：${q.scenarios.map(s => safe(s)).join("、")}</div>`
    : "";

  const tabsHtml = revealed ? `
      <div class="tabs">
        <button class="tab ${state.activePane === "answer" ? "active" : ""}" data-pane="answer">回到作答</button>
        <button class="tab ${state.activePane === "compare" ? "active" : ""}" data-pane="compare">左右對照檢視</button>
        <button class="tab ${state.activePane === "guide" ? "active" : ""}" data-pane="guide">資料補強</button>
        <button class="tab ${state.activePane === "skeleton" ? "active" : ""}" data-pane="skeleton">回答骨架</button>
      </div>` : "";

  const followHtml = revealed
    ? `<div class="follow"><b>已完成初稿：</b>請用下方左右對照檢查：左側保留原回答，右側勾選是否對應面向，並對照評審真正要看的能力與證據。</div>`
    : `<div class="lockedNotice"><b>先作答再看提示：</b>請先用自己的經驗完成初稿。完成後才會開啟左右對照檢視，避免一開始就被提示牽著走。</div>`;

  const actionButtons = revealed ? `
            <button type="button" class="good" id="saveDoneBtn">標記完成本題</button>
            <button type="button" class="secondary" id="copyBtn">複製我的回答</button>
            <button type="button" class="ghost" id="clearBtn">清除本題回答</button>
            <button type="button" class="ghost" onclick="window.print()">列印／另存PDF</button>
          ` : `
            <button type="button" class="good" id="revealBtn" ${answer.trim() ? "" : "disabled"}>我已完成初稿，進入左右對照檢視</button>
            <button type="button" class="secondary" id="copyBtn">複製我的回答</button>
            <button type="button" class="ghost" id="clearBtn">清除本題回答</button>
          `;

  const answerSnapshotHtml = answer.trim()
    ? safe(answer)
    : `<span class="answerEmpty">尚未輸入回答。</span>`;
  const dimensionChecksHtml = dimensionChecks.map((c, i) => `
            <label class="checkItem">
              <input type="checkbox" data-check="${i}" ${checks.includes(i) ? "checked" : ""}>
              <span>${safe(c)}</span>
            </label>
          `).join("");
  const structureChecksHtml = universalChecks.map((c, i) => {
    const idx = dimensionChecks.length + i;
    return `
            <label class="checkItem">
              <input type="checkbox" data-check="${idx}" ${checks.includes(idx) ? "checked" : ""}>
              <span>${safe(c)}</span>
            </label>
          `;
  }).join("");

  const revealPanes = revealed ? `
      <div class="pane ${state.activePane === "compare" ? "active" : ""}" id="pane-compare">
        <div class="reviewGrid">
          <div class="box answerReview">
            <h3>左側｜剛剛的作答</h3>
            <div class="answerSnapshot">${answerSnapshotHtml}</div>
            <div class="small" style="margin-top:8px;">先不要急著改寫。請先看右側：哪些面向有對應、哪些證據還缺。</div>
          </div>

          <div class="reviewRight">
            <div class="box">
              <h3>右上｜面向對應勾選</h3>
              <div class="scoreWrap" style="margin-bottom:10px;">
                <div class="scoreBar"><div class="scoreFill" id="scoreFill"></div></div>
                <div class="scoreText" id="scoreText">0%</div>
              </div>
              <div class="small" style="margin-bottom:8px;">先只勾「左側原回答已經有說到」的項目；不需要一次展開所有提醒。</div>
              <div class="checklist" id="checklist">
                ${dimensionChecksHtml}
              </div>
              <details class="compactDetails">
                <summary>展開基本完整性檢核（需要再補強時使用）</summary>
                <div class="checklist">
                  ${structureChecksHtml}
                </div>
              </details>
            </div>

            <div class="box judgeBox">
              <h3>右下｜評審視角要看到什麼</h3>
              <div class="judgeLead">${safe(q.observation)}</div>
              <div class="compactHint">
                <div class="hintPill"><b>追問方向：</b>${safe(q.followup || "請補充具體案例、成果與後續如何複製。")}</div>
                <div class="hintPill"><b>評分連結：</b>${safe(q.scoring || "應答內容切題性／口語表達與臺風／整體專業形象")}</div>
              </div>
            </div>
          </div>
        </div>
        <div class="revealPanel">
          <b>下一步：</b>只補「沒勾到但評審需要判斷」的內容；優先補案例、數字、前後差異或管理動作，不要新增口號。
        </div>
      </div>

      <div class="pane ${state.activePane === "guide" ? "active" : ""}" id="pane-guide">
        <div class="twoCol">
          ${q.guidance.map(g => `
            <div class="box">
              <h3>${safe(g.title)}</h3>
              <ul>${g.items.map(item => `<li>${safe(item)}</li>`).join("")}</ul>
            </div>
          `).join("")}
        </div>
      </div>

      <div class="pane ${state.activePane === "skeleton" ? "active" : ""}" id="pane-skeleton">
        <div class="box">
          <h3>建議回答骨架</h3>
          <ol>
            ${q.skeleton.map(item => `<li>${safe(item)}</li>`).join("")}
          </ol>
          <div class="notice" style="margin-top:12px;">
            請不要背稿。骨架的用途是幫你把自己的真實經驗，整理成評審聽得懂的管理邏輯。
          </div>
        </div>
        <div class="box">
          <h3>可複製成回答的通用句型</h3>
          <ul class="listCompact">
            <li>我當時觀察到的問題不是單一事件，而是＿＿＿＿。</li>
            <li>所以我先做＿＿＿＿，再帶同仁一起做＿＿＿＿。</li>
            <li>執行過程中，我用＿＿＿＿作為追蹤指標。</li>
            <li>最後帶來的改變是＿＿＿＿。</li>
            <li>這件事讓我確認，店長的角色不是只把事情做完，而是把方法留下來。</li>
          </ul>
        </div>
      </div>` : "";

  qs("questionCard").innerHTML = `
    <div class="questionHead">
      <div class="tags">${tagHtml}</div>
      <h2 class="question">${safe(q.question)}</h2>
      ${followHtml}
      <div class="practiceMeta">
        <span>目前題池：${state.pool.length} 題｜第 ${state.currentIndex + 1} 題</span>
        <span>${scenarioHtml}</span>
      </div>
    </div>
    <div class="questionBody">
      ${tabsHtml}

      <div class="pane ${state.activePane === "answer" ? "active" : ""}" id="pane-answer">
        <div class="box">
          <h3>我的初版回答</h3>
          <textarea id="answerBox" placeholder="請先用自己的經驗回答。建議順序：情境／問題 → 做法 → 團隊如何執行 → 成果 → 反思。">${safe(answer)}</textarea>
          <div class="btnRow" style="margin-top:10px;">
            ${actionButtons}
          </div>
          ${revealed ? `<div class="small" style="margin-top:8px;">後續檢視已開啟。可到「左右對照檢視」檢查回答缺口。</div>` : `<div class="small" style="margin-top:8px;">輸入內容後，才能開啟面向與檢核。</div>`}
        </div>
      </div>

      ${revealPanes}
    </div>
  `;

  document.querySelectorAll(".tab").forEach(btn => {
    btn.addEventListener("click", () => {
      state.activePane = btn.dataset.pane;
      renderQuestion(q);
    });
  });

  const answerBox = qs("answerBox");
  if (answerBox) {
    answerBox.addEventListener("input", () => {
      localStorage.setItem(storageKey(q.id), answerBox.value);
      const revealBtn = qs("revealBtn");
      if (revealBtn) revealBtn.disabled = answerBox.value.trim().length === 0;
    });
  }
  const revealBtn = qs("revealBtn");
  if (revealBtn) {
    revealBtn.addEventListener("click", () => {
      const latest = qs("answerBox") ? qs("answerBox").value.trim() : "";
      if (!latest) {
        alert("請先完成初稿，再開啟後續檢視。");
        return;
      }
      localStorage.setItem(revealKey(q.id), "1");
      state.activePane = "compare";
      renderQuestion(q);
    });
  }
  const doneBtn = qs("saveDoneBtn");
  if (doneBtn) {
    doneBtn.addEventListener("click", () => {
      localStorage.setItem(doneKey(q.id), "1");
      updateDoneStats();
      renderQuestion(q);
    });
  }
  const copyBtn = qs("copyBtn");
  if (copyBtn) {
    copyBtn.addEventListener("click", async () => {
      const text = buildCopyText(q);
      try {
        await navigator.clipboard.writeText(text);
        copyBtn.textContent = "已複製";
        setTimeout(() => copyBtn.textContent = "複製我的回答", 1200);
      } catch(e) {
        alert("瀏覽器未允許直接複製，請手動選取文字。");
      }
    });
  }
  const clearBtn = qs("clearBtn");
  if (clearBtn) {
    clearBtn.addEventListener("click", (event) => {
      event.preventDefault();
      clearCurrentQuestion(q);
    });
  }
  document.querySelectorAll("#checklist input").forEach(chk => {
    chk.addEventListener("change", () => {
      const selected = Array.from(document.querySelectorAll("#checklist input:checked")).map(x => Number(x.dataset.check));
      localStorage.setItem(checkKey(q.id), JSON.stringify(selected));
      updateScore();
    });
  });
  updateScore();
}

function clearCurrentQuestion(q) {
  localStorage.removeItem(storageKey(q.id));
  localStorage.removeItem(doneKey(q.id));
  localStorage.removeItem(checkKey(q.id));
  localStorage.removeItem(revealKey(q.id));
  const answerBox = qs("answerBox");
  if (answerBox) answerBox.value = "";
  document.querySelectorAll("#checklist input").forEach(chk => { chk.checked = false; });
  updateDoneStats();
  state.activePane = "answer";
  renderQuestion(q);
}

function updateScore() {
  const boxes = Array.from(document.querySelectorAll("#checklist input"));
  if (!boxes.length) return;
  const checked = boxes.filter(x => x.checked).length;
  const pct = Math.round(checked / boxes.length * 100);
  const fill = qs("scoreFill");
  const txt = qs("scoreText");
  if (fill) fill.style.width = pct + "%";
  if (txt) txt.textContent = pct + "%";
}

function buildCopyText(q) {
  const answer = localStorage.getItem(storageKey(q.id)) || "";
  return [
    "【TCFA 傑出店長應答練習】",
    "題號：" + q.id,
    "主題：" + q.topic,
    "題目：" + q.question,
    "追問：" + (q.followup || ""),
    "",
    "【我的回答】",
    answer,
    "",
    "【本題回答面向】",
    q.dimensions.join("、"),
    "",
    "【補強提醒】",
    "請確認回答中有：具體情境、管理動作、團隊參與、成果證據、可複製做法、店長反思。"
  ].join("\n");
}

function updateDoneStats() {
  const done = DATA.questions.filter(q => localStorage.getItem(doneKey(q.id)) === "1").length;
  qs("statDone").textContent = done;
}

window.addEventListener("DOMContentLoaded", init);
</script>

<script>
if ('serviceWorker' in navigator) {
  window.addEventListener('load', function () {
    navigator.serviceWorker.register('./service-worker.js').catch(function (error) {
      console.warn('Service Worker registration failed:', error);
    });
  });
}
</script>
</body>
</html>
